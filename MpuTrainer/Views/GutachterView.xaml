<UserControl x:Class="MpuTrainer.Views.GutachterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Kopf -->
            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="Gutachter" Style="{StaticResource PageTitle}"/>
                <TextBlock Style="{StaticResource PageSubtitle}" TextWrapping="Wrap"
                           Text="Realitätsnahe MPU-Simulation und vorbereitende psychologische Einschätzung – kein amtliches Gutachten. Jeder Fall wird als eigener Vorgang gespeichert und kann später wieder geöffnet werden."/>
            </StackPanel>

            <!-- Zwei Spalten: links neuer Fall, rechts gespeicherte Fälle -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Neuer Fall -->
                <Border Grid.Column="0" Style="{StaticResource Card}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Neuer Fall" Style="{StaticResource SectionHeader}"/>

                        <!-- Vor- und Nachname -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Vorname" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Nachname" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Geburtsdatum + Prüfungsdatum -->
                        <Grid Margin="0,10,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Geburtsdatum (TT.MM.JJJJ)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding BirthDate, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Datum der Prüfung" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding ExamDate, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Sprache + Fragestellung -->
                        <Grid Margin="0,10,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Sprache" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding LanguageOptions}"
                                          SelectedItem="{Binding SelectedLanguage}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Fragestellung" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding FragestellungOptions}"
                                          SelectedItem="{Binding SelectedFragestellung}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDescription}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Anzahl der Fragen -->
                        <TextBlock Text="Anzahl der Fragen" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" Minimum="1" Maximum="80" SmallChange="1" LargeChange="5"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    Value="{Binding QuestionCount}" VerticalAlignment="Center"
                                    Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding QuestionCount}" MinWidth="36"
                                       TextAlignment="Right" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </Grid>

                        <!-- Notizen -->
                        <TextBlock Text="Notizen (optional)" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="80"
                                 VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/>

                        <!-- Hinweis: Upload der Auffälligkeitsliste folgt -->
                        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="10" Padding="14" Margin="0,16,0,0">
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" LineHeight="20"
                                       Text="Im nächsten Schritt: Upload und Analyse der Auffälligkeitsliste, automatische Generierung individueller MPU-Fragen und Durchführung der Prüfung mit psychologischer Auswertung."/>
                        </Border>

                        <Button Content="Fall anlegen &amp; speichern" Style="{StaticResource PrimaryButton}"
                                Command="{Binding CreateCaseCommand}" HorizontalAlignment="Left" Margin="0,16,0,0"/>

                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,12,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Gespeicherte Fälle -->
                <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Gespeicherte Fälle" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Noch keine Fälle gespeichert."
                                   Foreground="{StaticResource SubtleTextBrush}" TextWrapping="Wrap"
                                   Margin="0,0,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Cases.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding Cases}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F6F7F9" CornerRadius="10" Padding="14" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="15"
                                                       Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DisplayLine}" FontSize="12.5"
                                                       Foreground="{StaticResource SubtleTextBrush}" TextWrapping="Wrap"
                                                       Margin="0,2,0,0"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <Button Content="Öffnen" Style="{StaticResource SecondaryButton}"
                                                        Margin="0,0,8,0"
                                                        Command="{Binding DataContext.OpenCaseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Löschen" Style="{StaticResource SecondaryButton}"
                                                        Command="{Binding DataContext.DeleteCaseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
