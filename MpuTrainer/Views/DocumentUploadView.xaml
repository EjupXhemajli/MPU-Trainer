<UserControl x:Class="MpuTrainer.Views.DocumentUploadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Leitfaden hochladen" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Word-, PDF- oder Textdokument hinzufügen. Es können mehrere Dokumente kombiniert werden – sie werden gemeinsam als Grundlage für die Fragen verwendet."
                       Style="{StaticResource PageSubtitle}" Margin="0,0,0,16"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Dokument hinzufügen (Word, PDF, Text)" Style="{StaticResource PrimaryButton}"
                            Command="{Binding ChooseFileCommand}"/>
                    <Button Content="Leitfaden leeren" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ClearLeitfadenCommand}" Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding SelectedFilePath}" VerticalAlignment="Center" Margin="14,0,0,0"
                               Foreground="{StaticResource SubtleTextBrush}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Background="#FFF6E5" BorderBrush="#E6B65C" BorderThickness="1" CornerRadius="8"
                        Padding="12,10" Margin="0,12,0,0"
                        Visibility="{Binding ScannedWarning, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock TextWrapping="Wrap" Foreground="#7A5A12"
                               Text="Das PDF scheint gescannt zu sein und enthält kaum lesbaren Text. Eine Texterkennung (OCR) ist in dieser Version noch nicht enthalten. Bitte ein Dokument mit auswählbarem Text verwenden."/>
                </Border>

                <Separator Margin="0,16,0,12" Background="{StaticResource BorderBrush}"/>

                <!-- Generierungs-Einstellungen des Projekts (jederzeit änderbar) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Sprache der Fragen und Sprachausgabe" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  MaxDropDownHeight="320"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Schwerpunkt der Fragen" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding FocusOptions}"
                                  SelectedItem="{Binding FocusCategory}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescription}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Anzahl der zu generierenden Fragen" Style="{StaticResource FieldLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" Minimum="5" Maximum="80"
                                    Value="{Binding QuestionCount}"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{StaticResource AppBackgroundBrush}"
                                    CornerRadius="6" Margin="8,0,0,0">
                                <TextBlock Text="{Binding QuestionCount}" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Diese Einstellungen gelten für dieses Projekt und werden sofort gespeichert. „Fragen generieren“ bzw. „Alle Fragen neu generieren“ verwendet sie."
                           Foreground="{StaticResource SubtleTextBrush}" FontSize="12.5"
                           TextWrapping="Wrap" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Textvorschau" Style="{StaticResource SectionHeader}"/>
                <TextBox Grid.Row="1" Text="{Binding PreviewText, Mode=OneWay}"
                         IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch"
                         Background="{StaticResource AppBackgroundBrush}"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="Fragen generieren" Style="{StaticResource PrimaryButton}"
                    Command="{Binding GenerateCommand}"/>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="14,0,0,0"
                       Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
