<UserControl x:Class="MpuTrainer.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel>
            <TextBlock Text="MPU-Trainer" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Wählen Sie einen Modus oder setzen Sie ein bestehendes Projekt fort."
                       Style="{StaticResource PageSubtitle}" Margin="0,0,0,20"/>

            <!-- ============ MODUSWAHL (Hauptmaske) ============ -->
            <StackPanel Margin="0,0,0,8">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowTrainingSetup}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Kachel: Trainingsmodus -->
                    <Button Grid.Column="0" Command="{Binding ChooseTrainingCommand}"
                            Cursor="Hand" HorizontalContentAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{StaticResource CardBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="14" Padding="26">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel>
                            <Border Width="54" Height="54" CornerRadius="13"
                                    Background="{StaticResource AccentSoftBrush}" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="25"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Trainingsmodus" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" Margin="0,16,0,6"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource SubtleTextBrush}" LineHeight="21"
                                       Text="Fragen üben: vorlesen lassen, Antwort aufnehmen und transkribieren, Musterantwort anhören und die Antwort psychologisch auswerten lassen."/>
                        </StackPanel>
                    </Button>

                    <!-- Kachel: Begutachtung -->
                    <Button Grid.Column="2" Command="{Binding ChooseBegutachtungCommand}"
                            Cursor="Hand" HorizontalContentAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{StaticResource CardBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="14" Padding="26">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel>
                            <Border Width="54" Height="54" CornerRadius="13"
                                    Background="{StaticResource AccentSoftBrush}" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="25"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Begutachtung" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" Margin="0,16,0,6"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource SubtleTextBrush}" LineHeight="21"
                                       Text="Realitätsnahe MPU-Simulation als eigener Fall – mit gutachterlicher Auswertung. Kein amtliches Gutachten."/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- ============ TRAININGS-SETUP ============ -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowTrainingSetup}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <Button Content="← Zurück zur Auswahl" Style="{StaticResource SecondaryButton}"
                        Command="{Binding BackToChoiceCommand}" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                <Border Style="{StaticResource Card}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Neues Trainingsprojekt" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Klientendaten" Style="{StaticResource FieldLabel}" Margin="0,4,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Vorname" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Familienname" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Geburtsdatum" Style="{StaticResource FieldLabel}" Margin="0,12,0,0"/>
                        <DatePicker SelectedDate="{Binding BirthDate}"/>

                        <TextBlock Text="Projektname" Style="{StaticResource FieldLabel}" Margin="0,12,0,0"/>
                        <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Schwerpunkt der Fragen" Style="{StaticResource FieldLabel}" Margin="0,12,0,0"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding FocusCategory}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescription}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Sprache der Fragen und Sprachausgabe" Style="{StaticResource FieldLabel}" Margin="0,12,0,0"/>
                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  MaxDropDownHeight="320"/>
                        <TextBlock Text="Fragen und Musterantworten werden in dieser Sprache erstellt und vorgelesen."
                                   Foreground="{StaticResource SubtleTextBrush}" FontSize="12.5"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>

                        <TextBlock Text="Anzahl der zu generierenden Fragen" Style="{StaticResource FieldLabel}" Margin="0,12,0,0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" Minimum="5" Maximum="80"
                                    Value="{Binding QuestionCount}"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{StaticResource AppBackgroundBrush}"
                                    CornerRadius="6" Margin="8,0,0,0">
                                <TextBlock Text="{Binding QuestionCount}" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <Button Content="Projekt erstellen und Leitfaden hochladen"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding CreateProjectCommand}"
                                HorizontalAlignment="Left" Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ============ LETZTE PROJEKTE (immer sichtbar) ============ -->
            <Border Style="{StaticResource Card}" VerticalAlignment="Top" Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock Text="Letzte Projekte" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="Keine Projekte vorhanden."
                               Foreground="{StaticResource SubtleTextBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentProjects.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding RecentProjects}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Command="{Binding DataContext.OpenProjectCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            HorizontalContentAlignment="Stretch"
                                            Cursor="Hand"
                                            Padding="12,10">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{StaticResource AppBackgroundBrush}"
                                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="BorderBrush"
                                                                Value="{StaticResource AccentBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Client.FullName}"
                                                       Foreground="{StaticResource SubtleTextBrush}" FontSize="12"/>
                                            <TextBlock Foreground="{StaticResource SubtleTextBrush}" FontSize="12">
                                                <Run Text="{Binding CreatedUtc, StringFormat='{}{0:dd.MM.yyyy}', Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding QuestionCount, Mode=OneWay}"/>
                                                <Run Text=" Fragen"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="1" Width="46" Margin="8,0,0,0" Cursor="Hand"
                                            ToolTip="Projekt löschen"
                                            Command="{Binding DataContext.DeleteProjectCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Db" Background="{StaticResource AppBackgroundBrush}"
                                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                        CornerRadius="8">
                                                    <TextBlock Text="🗑" FontSize="15" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" Foreground="{StaticResource SubtleTextBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Db" Property="BorderBrush" Value="#C0392B"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
