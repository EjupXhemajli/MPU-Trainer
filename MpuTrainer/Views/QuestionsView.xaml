<UserControl x:Class="MpuTrainer.Views.QuestionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Fragenübersicht" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="{Binding ProjectTitle}" Style="{StaticResource PageSubtitle}" Margin="0,0,0,16"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Frage hinzufügen" Style="{StaticResource SecondaryButton}"
                    Command="{Binding AddQuestionCommand}"/>
            <Button Content="Alle Fragen neu generieren" Style="{StaticResource SecondaryButton}"
                    Command="{Binding RegenerateAllCommand}"/>
            <Button Content="Speichern" Style="{StaticResource SecondaryButton}"
                    Command="{Binding SaveCommand}"/>
            <Button Content="Als Word speichern" Style="{StaticResource SecondaryButton}"
                    Command="{Binding ExportWordCommand}"/>
            <TextBlock Text="Bitte warten…" VerticalAlignment="Center" Margin="6,0,0,0"
                       Foreground="{DynamicResource OnBgSubtleBrush}"
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Questions}"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      RowBackground="White" AlternatingRowBackground="#F7F9FC"
                      BorderThickness="0" Background="Transparent"
                      VerticalGridLinesBrush="{StaticResource BorderBrush}"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      RowHeaderWidth="0" CanUserResizeRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nr." Binding="{Binding Order}" Width="48" IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="Frage" Width="2.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         BorderThickness="0" Background="Transparent" Padding="6,4"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Kategorie" Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ItemsSource="{Binding DataContext.Categories, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          BorderThickness="0" Background="Transparent" Margin="2">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDescription}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Schwierigkeit" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding Difficulty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ItemsSource="{Binding DataContext.Difficulties, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          BorderThickness="0" Background="Transparent" Margin="2" MinWidth="90">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDescription}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Status" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ItemsSource="{Binding DataContext.Statuses, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          BorderThickness="0" Background="Transparent" Margin="2" MinWidth="100">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDescription}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Musterantwort (optional)" Width="1.8*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding ModelAnswer, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         BorderThickness="0" Background="Transparent" Padding="6,4"
                                         Foreground="{StaticResource SubtleTextBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Löschen"
                                        Command="{Binding DataContext.DeleteQuestionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#C0392B" Cursor="Hand" Padding="10,4" Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Training starten ▶" Style="{StaticResource PrimaryButton}"
                    Command="{Binding StartTrainingCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
