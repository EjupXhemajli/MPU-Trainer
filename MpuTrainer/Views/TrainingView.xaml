<UserControl x:Class="MpuTrainer.Views.TrainingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Kopfzeile: Titel + Fortschritt + Sitzung speichern -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Trainingsmodus" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="{Binding ProgressText}" Foreground="{DynamicResource OnBgSubtleBrush}"
                           FontSize="14.5" Margin="0,2,0,8"/>
                <ProgressBar Minimum="0" Maximum="1" Value="{Binding ProgressValue}" Height="7"
                             MaxWidth="520" HorizontalAlignment="Left"
                             Foreground="{StaticResource AccentBrush}" Background="#E3E6EA"
                             BorderThickness="0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Sitzung als Word speichern"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"
                            Command="{Binding SaveSessionWordCommand}"/>
                    <Button Content="Gesamte Sitzung als MP3 speichern"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding BuildSessionCommand}"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,8,0,0"
                             Foreground="{StaticResource AccentBrush}" Background="Transparent"
                             BorderThickness="0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Aktuelle Frage (hervorgehoben mit Akzentleiste) -->
                <Border Style="{StaticResource Card}" Padding="0" BorderThickness="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource AccentBrush}" CornerRadius="14,0,0,14"/>
                        <StackPanel Grid.Column="1" Margin="24">
                            <Border Style="{StaticResource CategoryBadge}" Margin="0,0,0,14">
                                <TextBlock Text="{Binding CurrentQuestion.Category, Converter={StaticResource EnumDescription}}"
                                           Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" FontSize="12.5"/>
                            </Border>
                            <TextBlock Text="{Binding CurrentQuestion.Text}" TextWrapping="Wrap"
                                       FontSize="23" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                       LineHeight="32"/>
                            <Button Content="🔊  Frage anhören" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding PlayQuestionCommand}"
                                    HorizontalAlignment="Left" Margin="0,20,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Antwort des Klienten -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Antwort des Klienten" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Mikrofonpegel" Style="{StaticResource FieldLabel}"/>
                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding Level}" Height="10"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="#EEF0F3" BorderThickness="0"/>

                        <WrapPanel Margin="0,16,0,0">
                            <Button Command="{Binding ToggleRecordingCommand}" Margin="0,0,12,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                        <Setter Property="Content" Value="●  Antwort aufnehmen"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                <Setter Property="Content" Value="■  Aufnahme stoppen"/>
                                                <Setter Property="Background" Value="#C0392B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="▶  Meine Antwort anhören" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding PlayMyAnswerCommand}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Auswertung der Antwort -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Auswertung der Antwort" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Vergleicht die aufgenommene Antwort mit der Musterantwort: Übereinstimmung im Kern, Abweichungen, was noch nicht verstanden wurde, und Verbesserungsvorschläge."
                                   Style="{StaticResource FieldLabel}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <Button Content="🔍  Antwort auswerten" Style="{StaticResource PrimaryButton}"
                                Command="{Binding EvaluateAnswerCommand}" HorizontalAlignment="Left"/>

                        <!-- Ladeanzeige während Transkription/Auswertung -->
                        <ProgressBar IsIndeterminate="True" Height="4" Margin="0,12,0,0"
                                     Foreground="{StaticResource AccentBrush}" Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="{Binding IsEvaluating, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Ergebnis (Transkript + MP3 + Auswertung) -->
                        <StackPanel Margin="0,14,0,0"
                                    Visibility="{Binding HasEvaluation, Converter={StaticResource BoolToVisibility}}">
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Antwort des Klienten (Transkript)" Style="{StaticResource FieldLabel}"
                                           VerticalAlignment="Center"/>
                                <Button Content="📁  Antwort als MP3 öffnen" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding OpenAnswerMp3Command}" HorizontalAlignment="Right"
                                        Visibility="{Binding HasAnswerMp3, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>
                            <Border Background="#EDEFF2" CornerRadius="10" Padding="16" Margin="0,4,0,16">
                                <TextBlock Text="{Binding Transcript}" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextBrush}" LineHeight="25" FontSize="16"/>
                            </Border>

                            <TextBlock Text="Auswertung" Style="{StaticResource FieldLabel}"/>
                            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="10" Padding="18" Margin="0,4,0,0">
                                <TextBlock Text="{Binding EvaluationText}" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextBrush}" LineHeight="28" FontSize="17.5"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Musterantwort -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Musterantwort" Style="{StaticResource SectionHeader}"/>
                        <Button Content="▶  Musterantwort anhören" Style="{StaticResource SuccessButton}"
                                Command="{Binding PlayModelAnswerCommand}"
                                HorizontalAlignment="Left"/>
                        <Border Background="#F6F7F9" CornerRadius="10" Padding="16" Margin="0,14,0,0">
                            <TextBlock Text="{Binding ModelAnswerText}" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextBrush}" LineHeight="23"
                                       FontSize="15" MinHeight="42"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Fußzeile: Navigation + Status -->
        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="◀  Zurück" Style="{StaticResource SecondaryButton}"
                    Command="{Binding PreviousQuestionCommand}"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center"
                       HorizontalAlignment="Center" TextWrapping="Wrap" Margin="16,0"
                       Foreground="{DynamicResource OnBgSubtleBrush}"/>
            <Button Grid.Column="2" Content="Nächste Frage  ▶" Style="{StaticResource PrimaryButton}"
                    Command="{Binding NextQuestionCommand}"/>
        </Grid>
    </Grid>
</UserControl>
